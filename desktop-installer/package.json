{
  "name": "alsalik-pos",
  "productName": "Al Salik POS",
  "version": "1.0.0",
  "description": "Point of Sale system by Al Salik Computers",
  "main": "main.js",
  "author": {
    "name": "Al Salik Computers",
    "email": "info@alsalikcomputers.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win32": "electron-builder --win --ia32",
    "build:all": "electron-builder --win --x64 --ia32"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.alsalikcomputers.pos",
    "productName": "Al Salik POS",
    "copyright": "© 2025 Al Salik Computers. All rights reserved.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Al Salik Computers",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Al Salik POS",
      "menuCategory": "Al Salik Computers",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "license": "LICENSE.txt",
      "language": "1033",
      "include": "installer.nsh"
    },
    "extraMetadata": {
      "version": "1.0.0"
    }
  }
}
